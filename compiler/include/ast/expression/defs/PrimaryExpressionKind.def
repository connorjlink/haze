// NOTE: associativity is meaningless for primary expressions so a default of LEFT is safe
X(IDENTIFIER, LEFT, 0, identifier)
X(INTEGER_LTIERAL, LEFT, 0, integer literal)
X(FLOAT_LITERAL, LEFT, 0, float literal)
X(CHARACTER_LITERAL, LEFT, 0, character literal)
X(STRING_LITERAL, LEFT, 0, string literal)
X(PARENTHESIZED, LEFT, 0, parenthesized)
