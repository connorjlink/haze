X(ADD, +, add)
X(SUBTRACT, -, subtract)
X(MULTIPLY, *, multiply)
X(DIVIDE, /, divide)
X(UNSIGNED_DIVIDE, u./, unsigned divide)
X(MODULO, %, modulo)
X(UNSIGNED_MODULO, u.%, unsigned modulo)
X(AND, &, bitwise and)
X(OR, |, bitwise or)
X(XOR, ^, bitwise xor)
X(SHIFT_LEFT, <<, bitwise shift left)
X(SHIFT_RIGHT, >>, bitwise shift right)
X(UNSIGNED_SHIFT_RIGHT, u.>>, unsigned bitwise shift right)
